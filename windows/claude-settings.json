{
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/c/msys64/usr/bin/bash.exe /c/Users/apfba/.tmux/hook-stop.sh; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/c/msys64/usr/bin/bash.exe /c/Users/apfba/.tmux/hook-pretooluse.sh; true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/c/msys64/usr/bin/bash.exe /c/Users/apfba/.tmux/hook-notification.sh; true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status*)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(echo *)",
      "Bash(grep *)"
    ]
  }
}
